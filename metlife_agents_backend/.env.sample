# MetLife Agents Backend - sample environment variables
# Copy to `.env` and fill the values for your environment.

# -----------------------------------------------------------------------------
# API / Server
# -----------------------------------------------------------------------------
PROJECT_NAME=metlife-agents-backend
BACKEND_CORS_ORIGINS=
API_VER_STR_V1=/api/v1

# -----------------------------------------------------------------------------
# Database (Postgres if configured; otherwise SQLite fallback)
# -----------------------------------------------------------------------------
POSTGRES_DB_NAME=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=

# SQLite DB file path (relative paths are resolved under `metlife_agents_backend/`)
SQLITE_DB_PATH=metlife_agents.db

# -----------------------------------------------------------------------------
# Azure OpenAI (optional; if unset, LLM nodes run in fallback mode)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5
AZURE_OPENAI_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# Send engine quiet hours (JST)
# -----------------------------------------------------------------------------
QUIET_START_JST_HOUR=21
QUIET_END_JST_HOUR=8

# -----------------------------------------------------------------------------
# Per-scenario cadence (days between nurture emails)
# -----------------------------------------------------------------------------
CADENCE_DAYS_S1=3
CADENCE_DAYS_S2=3
CADENCE_DAYS_S3=1
CADENCE_DAYS_S4=7
CADENCE_DAYS_S5=2
CADENCE_DAYS_S6=0
CADENCE_DAYS_S7=0

# -----------------------------------------------------------------------------
# Internal timer processor (cadence + quiet-hours + S4 response timers)
# -----------------------------------------------------------------------------
AUTO_TIMER_PROCESSOR_ENABLED=true
AUTO_TIMER_PROCESSOR_INTERVAL_SECONDS=30
AUTO_TIMER_PROCESSOR_LIMIT=25

